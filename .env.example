# ── User ──────────────────────────────────────────────────────────────
USER_NAME=YourName

# ── Projects (folder mounted into Docker) ────────────────────────────
PROJECTS_PATH=/path/to/your/projects

# ── Claude Code Auth (Max subscription) ──────────────────────────────
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxx

# ── Telegram Bot ─────────────────────────────────────────────────────
# Get this from @BotFather on Telegram after creating your bot
TELEGRAM_BOT_TOKEN=7123456789:AAH-xxxxx

# ── Security: only your Telegram account can use the bot ─────────────
# Get this from @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=your_user_id

# ── Model ────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6

# ── Voice ────────────────────────────────────────────────────────────
TTS_HOST=http://host.docker.internal:8880
TTS_VOICE=ryan

# ── Dashboard ────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=your_password

# ── Trading (exchange for live mode) ──────────────────────────────────
# TRADING_ENABLED=true
# TRADING_MODE=paper
# EXCHANGE_ID=kraken
# EXCHANGE_API_KEY=your_api_key
# EXCHANGE_API_SECRET=your_api_secret

# ── Kraken CLI MCP (market data + paper trading via MCP server) ──────
# KRAKEN_CLI_ENABLED=true
# KRAKEN_API_KEY=your_kraken_api_key
# KRAKEN_API_SECRET=your_kraken_api_secret

# ── Memory (Mem0 — optional, defaults work with Docker networking) ───
# MEM0_ENABLED=true
# OLLAMA_HOST=http://ollama:11434
# QDRANT_HOST=qdrant

# ── User ──────────────────────────────────────────────────────────────
USER_NAME=YourName

# ── Projects (folder mounted into Docker) ────────────────────────────
PROJECTS_PATH=/path/to/your/projects

# ── Claude Code Auth (Max subscription) ──────────────────────────────
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxx

# ── Telegram Bot ─────────────────────────────────────────────────────
# Get this from @BotFather on Telegram after creating your bot
TELEGRAM_BOT_TOKEN=7123456789:AAH-xxxxx

# ── Security: only your Telegram account can use the bot ─────────────
# Get this from @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=your_user_id

# ── Model ────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6

# ── Voice ────────────────────────────────────────────────────────────
TTS_HOST=http://host.docker.internal:8880
TTS_VOICE=ryan

# ── Dashboard ────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=your_password
